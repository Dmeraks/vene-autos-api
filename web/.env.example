# URL pública del sitio (sin barra final). Obligatorio en build de producción para canonical, Open Graph y JSON-LD.
# VITE_SITE_URL=https://www.veneautos.com.co

# Opcional: ciudad para título/meta y dirección en datos estructurados (Google).
# VITE_BUSINESS_LOCALITY=Bogotá

# Origen del API Nest (sin /api/v1). Obligatorio si ves «Cannot GET /api/v1/...» al cargar datos.
# Desarrollo típico: copiá a .env y ajustá el puerto si hace falta.
# VITE_API_BASE=http://localhost:3000
