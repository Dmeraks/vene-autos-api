# Guía paso a paso (BD, migraciones, seed, probar login): docs/PRIMER_PASO.md
#
# Node.js: usar LTS 20.x (ver `api/.nvmrc` y `engines` en package.json). Evita 24+ en prod hasta validar.

# PostgreSQL (docker-compose o instancia propia)
DATABASE_URL="postgresql://vene:vene@localhost:5432/vene_autos?schema=public"

# JWT — usar un secreto largo en producción
JWT_SECRET="cambiar-por-secreto-largo-en-produccion"
# Caducidad del token (p. ej. 12h). La sesión también se cierra por inactividad (ver configuración auth.session_idle_timeout_minutes).
JWT_EXPIRES_IN="12h"

PORT=3000

# production | development (afecta valor por defecto de CORS si CORS_ORIGIN está vacío)
NODE_ENV=development

# Detrás de Nginx/Ingress: permite req.ip / rate limit por cliente real
TRUST_PROXY=false

# Cabeceras HTTP endurecidas (helmet). false = desactivar (solo depuración local)
HELMET_ENABLED=true

# Auditoría HTTP (mutaciones). false = solo auditoría de dominio explícita
AUDIT_HTTP=true

# Registro público /auth/register (desactivado por defecto)
ALLOW_PUBLIC_REGISTRATION=false

# Origen CORS separado por coma, o * (solo desarrollo; en producción * se ignora)
CORS_ORIGIN=http://localhost:5173

# Credenciales del admin inicial (solo seed)
SEED_ADMIN_EMAIL=admin@veneautos.local
SEED_ADMIN_PASSWORD=ChangeMe!123

# --- Cuando tengas PostgreSQL (Docker o nube) ---
# 1) Crea la base (ej. CREATE DATABASE vene_autos;)
# 2) Pon DATABASE_URL arriba apuntando a esa base
# 3) npx prisma migrate deploy
# 4) npx prisma generate
# 5) npx prisma db seed
# Ajustes editables luego vía GET/PATCH /api/v1/settings (permiso settings:update):
#   - auth.session_idle_timeout_minutes (1–1440, default 10)
#   - users.create_requires_dueno_role (true = solo rol "dueno" puede POST /users)

# --- Producción (recomendado) ---
# NODE_ENV=production
# CORS_ORIGIN=https://app.tudominio.com
# TRUST_PROXY=true
# HELMET_ENABLED=true
# ALLOW_PUBLIC_REGISTRATION=false
