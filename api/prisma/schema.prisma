generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Cuenta humana del sistema. Las reglas de acceso vienen de roles → permisos.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles           UserRole[]
  auditLogs       AuditLog[]        @relation("AuditActor")
  settingsUpdated WorkshopSetting[] @relation("SettingUpdater")

  cashSessionsOpened          CashSession[]         @relation("CashSessionOpenedBy")
  cashSessionsClosed          CashSession[]         @relation("CashSessionClosedBy")
  cashMovementsCreated        CashMovement[]        @relation("CashMovementCreatedBy")
  cashExpenseDelegate         CashExpenseDelegate?  @relation("CashExpenseDelegateUser")
  cashDelegatesAssigned       CashExpenseDelegate[] @relation("CashExpenseDelegateAssigner")
  cashExpenseRequestsCreated  CashExpenseRequest[]  @relation("CashExpenseRequestRequester")
  cashExpenseRequestsReviewed CashExpenseRequest[]  @relation("CashExpenseRequestReviewer")
  authSessions                UserAuthSession[]
  workOrdersCreated           WorkOrder[]           @relation("WorkOrderCreatedBy")
  workOrdersAssigned          WorkOrder[]           @relation("WorkOrderAssignedTo")
  workOrderPaymentsRecorded   WorkOrderPayment[]     @relation("WorkOrderPaymentRecordedBy")
  inventoryMovementsCreated   InventoryMovement[]    @relation("InventoryMovementCreatedBy")
  purchaseReceiptsReceived    PurchaseReceipt[]     @relation("PurchaseReceiptReceivedBy")
  salesCreated                Sale[]                @relation("SaleCreatedBy")
  salePaymentsRecorded        SalePayment[]         @relation("SalePaymentRecordedBy")
  fiscalResolutionsCreated    FiscalResolution[]    @relation("FiscalResolutionCreatedBy")
  invoicesCreated             Invoice[]             @relation("InvoiceCreatedBy")
  invoiceDispatchRequested    InvoiceDispatchEvent[] @relation("InvoiceDispatchRequestedBy")
  creditNotesCreated          CreditNote[]          @relation("CreditNoteCreatedBy")
  creditNotesIssued           CreditNote[]          @relation("CreditNoteIssuedBy")
  creditNotesVoided           CreditNote[]          @relation("CreditNoteVoidedBy")
  debitNotesCreated           DebitNote[]           @relation("DebitNoteCreatedBy")
  debitNotesIssued            DebitNote[]           @relation("DebitNoteIssuedBy")
  debitNotesVoided            DebitNote[]           @relation("DebitNoteVoidedBy")
  invoicePaymentsRecorded     InvoicePayment[]      @relation("InvoicePaymentRecordedBy")
  /// Cliente del taller enlazado para el rol portal (ver solo OT de vehículos de ese cliente).
  portalCustomerId String?   @map("portal_customer_id")
  portalCustomer   Customer? @relation("UserPortalCustomer", fields: [portalCustomerId], references: [id], onDelete: SetNull)

  @@index([portalCustomerId])
  @@map("users")
}

/// Cliente del taller (persona o empresa de contacto).
model Customer {
  id           String   @id @default(cuid())
  displayName  String   @map("display_name") @db.VarChar(200)
  primaryPhone String?  @map("primary_phone") @db.VarChar(40)
  email        String?  @db.VarChar(120)
  documentId   String?  @map("document_id") @db.VarChar(40)
  notes        String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vehicles    Vehicle[]
  portalUsers User[] @relation("UserPortalCustomer")
  sales       Sale[]
  invoices    Invoice[]

  @@map("customers")
}

/// Vehículo registrado a nombre de un cliente (historial de OT por `work_orders.vehicle_id`).
model Vehicle {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  /// Placa tal como se muestra en UI (puede tener espacios).
  plate      String   @db.VarChar(20)
  /// Placa normalizada (mayúsculas, sin espacios): unicidad en el taller.
  plateNorm  String   @unique @map("plate_norm") @db.VarChar(20)
  vin        String?  @db.VarChar(32)
  brand      String?  @db.VarChar(80)
  model      String?  @db.VarChar(80)
  year       Int?     @db.SmallInt
  color      String?  @db.VarChar(40)
  notes      String?  @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  workOrders WorkOrder[]

  @@index([customerId])
  @@map("vehicles")
}

/// Sesión de acceso al API: una activa por usuario al iniciar sesión; se invalida al entrar desde otro sitio o por inactividad.
model UserAuthSession {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  createdFromIp  String?   @map("created_from_ip")
  userAgent      String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("user_auth_sessions")
}

/// Estado de una sesión de caja: solo una fila debería estar OPEN a la vez (regla en aplicación).
enum CashSessionStatus {
  OPEN
  CLOSED
}

/// Dirección contable del movimiento; debe coincidir con la categoría elegida.
enum CashMovementDirection {
  INCOME
  EXPENSE
}

/// Ciclo de vida de una solicitud de egreso (aprobación asíncrona por dueño/administrador).
enum CashExpenseRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

/// Estados de la orden de trabajo (Fase 3). Transiciones válidas en servicio de aplicación.
enum WorkOrderStatus {
  /// En cola del taller; sin técnico asignado hasta que alguien la tome o se reasigne.
  UNASSIGNED
  RECEIVED
  IN_WORKSHOP
  WAITING_PARTS
  READY
  DELIVERED
  CANCELLED
}

/// Línea de OT: repuesto (descuenta inventario) o mano de obra (importe al cliente, sin stock).
enum WorkOrderLineType {
  PART
  LABOR
}

/// Cómo se pagó la mercadería de la recepción (egreso físico en caja solo si es efectivo desde caja).
enum PurchaseReceiptPaymentSource {
  CASH_REGISTER
  BANK_TRANSFER
}

/// Cobro en caja desde la OT: abono (no cierra) vs liquidación total (entrega y bloqueo de edición).
enum WorkOrderPaymentKind {
  PARTIAL
  FULL_SETTLEMENT
}

/// Movimiento de stock (cantidad con signo: positivo entra, negativo sale).
enum InventoryMovementType {
  PURCHASE_IN
  WORK_ORDER_CONSUMPTION
  /// Consumo de inventario por venta de mostrador (origen COUNTER).
  /// Las ventas con origen WORK_ORDER NO producen este tipo (la OT ya descontó).
  SALE_CONSUMPTION
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

/// Estado de una venta / comprobante de mostrador.
enum SaleStatus {
  /// Editable, aún no impacta inventario ni puede recibir pagos.
  DRAFT
  /// Emitida al cliente: inventario descontado (si origen COUNTER) y lista para cobro.
  CONFIRMED
  /// Anulada: se permite únicamente si no tiene pagos y se reintegra el stock consumido.
  CANCELLED
}

/// Cómo nació la venta: mostrador puro vs. facturación de una OT ya entregada.
enum SaleOrigin {
  COUNTER
  WORK_ORDER
}

/// Tipo de línea de venta (paralelo a la OT).
enum SaleLineType {
  PART
  LABOR
}

/// Cobro en caja desde una venta: abono (deja saldo) vs. liquidación total.
enum SalePaymentKind {
  PARTIAL
  FULL_SETTLEMENT
}

/// Clasificación fiscal/operativa del ítem de inventario.
/// - PART: repuesto que se cobra al cliente y lleva stock.
/// - SUPPLY: insumo interno del taller (se consume pero no necesariamente se cobra aparte).
/// - PRODUCT: producto terminado para venta directa (mostrador).
/// Separar los servicios del inventario es importante fiscalmente (IVA y retenciones diferentes).
enum InventoryItemKind {
  PART
  SUPPLY
  PRODUCT
}

/// Familia del impuesto indirecto aplicable a una línea.
/// - VAT: IVA (19/5/0 %). Es lo habitual.
/// - INC: Impuesto al consumo (reservado; habilitar solo si el taller lo causa).
enum TaxRateKind {
  VAT
  INC
}

/// Orden de trabajo del taller. Puede enlazar a `Vehicle` (cliente formal); los campos texto siguen por compatibilidad y búsquedas.
model WorkOrder {
  id            String          @id @default(cuid())
  orderNumber   Int             @unique @default(autoincrement()) @map("order_number")
  /// Código para comprobante y seguimiento (ej. VEN-0001). Se asigna al crear según `order_number`.
  publicCode    String          @unique @map("public_code") @db.VarChar(32)
  status        WorkOrderStatus @default(UNASSIGNED)
  description   String
  /// Vehículo registrado (historial unificado); opcional durante migración desde texto.
  vehicleId     String?         @map("vehicle_id")
  customerName  String?         @map("customer_name")
  customerPhone String?         @map("customer_phone")
  /// Correo del cliente en esta OT (p. ej. facturación; puede copiarse del maestro al enlazar vehículo).
  customerEmail String?         @map("customer_email") @db.VarChar(120)
  vehiclePlate  String?         @map("vehicle_plate")
  /// Marca declarada al ingreso (texto libre; si hay vehículo enlazado se puede rellenar desde el maestro).
  vehicleBrand  String?         @map("vehicle_brand") @db.VarChar(80)
  /// Modelo declarado al ingreso (instantánea en la OT).
  vehicleModel  String?         @map("vehicle_model") @db.VarChar(80)
  /// Línea del vehículo (p. ej. licencia de tránsito / OCR).
  vehicleLine       String?     @map("vehicle_line") @db.VarChar(120)
  /// Cilindraje en cc tal como en documento (texto libre).
  vehicleCylinderCc String?     @map("vehicle_cylinder_cc") @db.VarChar(32)
  vehicleColor    String?       @map("vehicle_color") @db.VarChar(80)
  vehicleNotes  String?         @map("vehicle_notes")
  internalNotes String?         @map("internal_notes")
  /// Odómetro al ingreso del vehículo (instantánea para esta OT).
  intakeOdometerKm Int?        @map("intake_odometer_km")
  /// Solo revisión / diagnóstico: el cargo al cliente debe figurar como línea de mano de obra (flujo de cobro habitual).
  inspectionOnly Boolean       @default(false) @map("inspection_only")
  /// Tope opcional de cobros en caja para esta OT; si es null, no hay tope en sistema (solo montos válidos).
  authorizedAmount Decimal?    @map("authorized_amount") @db.Decimal(18, 2)
  /// Texto de consentimiento mostrado al firmar (copia para auditoría).
  clientConsentTextSnapshot String?   @map("client_consent_text_snapshot") @db.Text
  clientConsentSignedAt     DateTime? @map("client_consent_signed_at")
  /// PNG en base64 (sin prefijo data:); solo se escribe una vez por orden.
  clientSignaturePngBase64  String?   @map("client_signature_png_base64") @db.Text
  deliveredAt   DateTime?       @map("delivered_at")
  /// OT origen (p. ej. trabajo ya entregado) cuando esta orden es una **garantía** o seguimiento vinculado.
  parentWorkOrderId String?   @map("parent_work_order_id")
  createdById   String          @map("created_by_id")
  assignedToId  String?         @map("assigned_to_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  createdBy  User  @relation("WorkOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo User? @relation("WorkOrderAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  parentWorkOrder WorkOrder?  @relation("WorkOrderWarrantyParent", fields: [parentWorkOrderId], references: [id], onDelete: Restrict)
  warrantyFollowUps WorkOrder[] @relation("WorkOrderWarrantyParent")
  payments   WorkOrderPayment[]
  lines      WorkOrderLine[]
  /// Venta emitida a partir de esta OT (1:1 opcional).
  sale       Sale?
  invoices   Invoice[]

  @@index([status, createdAt])
  @@index([vehicleId])
  @@index([parentWorkOrderId])
  /// Fase 8 · Informe «Utilidad por técnico»: filtra DELIVERED por rango de `deliveredAt` agrupando por `assignedToId`.
  @@index([assignedToId, deliveredAt])
  @@map("work_orders")
}

/// Cobro registrado en caja vinculado a una OT (1:1 con el movimiento de ingreso).
model WorkOrderPayment {
  id             String               @id @default(cuid())
  workOrderId    String               @map("work_order_id")
  amount         Decimal              @db.Decimal(18, 2)
  kind           WorkOrderPaymentKind @default(PARTIAL)
  cashMovementId String               @unique @map("cash_movement_id")
  note           String?
  recordedById   String               @map("recorded_by_id")
  createdAt      DateTime             @default(now()) @map("created_at")

  workOrder    WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  cashMovement CashMovement @relation(fields: [cashMovementId], references: [id], onDelete: Restrict)
  recordedBy   User         @relation("WorkOrderPaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([workOrderId, createdAt])
  @@map("work_order_payments")
}

/// Unidad de medida (catálogo ampliable por migración o seed).
model MeasurementUnit {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0) @map("sort_order")

  items InventoryItem[]

  @@map("measurement_units")
}

/// Ítem de inventario (repuesto/material con stock).
model InventoryItem {
  id                 String   @id @default(cuid())
  sku                String   @unique @db.VarChar(80)
  /// Proveedor comercial (puede repetirse entre ítems; distinto de categoría).
  supplier           String   @default("") @db.VarChar(200) @map("supplier")
  /// Rubro / tipo de producto (aceites, eléctrico, etc.).
  category           String   @default("") @db.VarChar(200) @map("category")
  /// Clasificación fiscal/operativa: repuesto, insumo interno o producto de mostrador.
  itemKind           InventoryItemKind @default(PART) @map("item_kind")
  name               String   @db.VarChar(200)
  /// Referencia corta del fabricante o número de parte (p. ej. "# 00", "K-2015").
  /// Campo opcional que se muestra en tabla/recibo separado del nombre cuando está presente.
  reference          String   @default("") @db.VarChar(120) @map("reference")
  measurementUnitId  String   @map("measurement_unit_id")
  quantityOnHand     Decimal  @default(0) @map("quantity_on_hand") @db.Decimal(18, 4)
  averageCost        Decimal? @map("average_cost") @db.Decimal(18, 2)
  trackStock         Boolean  @default(true) @map("track_stock")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  measurementUnit      MeasurementUnit       @relation(fields: [measurementUnitId], references: [id], onDelete: Restrict)
  movements            InventoryMovement[]
  workOrderLines        WorkOrderLine[]
  purchaseReceiptLines PurchaseReceiptLine[]
  saleLines            SaleLine[]
  invoiceLines         InvoiceLine[]

  @@index([measurementUnitId])
  /// Fase 8 · Informe «Stock crítico»: filtra `isActive=true` + `trackStock=true` y ordena por `quantityOnHand`.
  @@index([isActive, trackStock])
  @@map("inventory_items")
}

/// Recepción de compra (entrada de mercadería al taller).
model PurchaseReceipt {
  id             String                       @id @default(cuid())
  note           String?                      @db.Text
  supplierRef    String?                      @map("supplier_ref") @db.VarChar(200)
  receivedById   String                       @map("received_by_id")
  /// Efectivo desde caja (egreso en sesión abierta) vs pago bancario (sin movimiento de caja física).
  paymentSource  PurchaseReceiptPaymentSource @default(BANK_TRANSFER) @map("payment_source")
  createdAt      DateTime                     @default(now()) @map("created_at")

  receivedBy User                 @relation("PurchaseReceiptReceivedBy", fields: [receivedById], references: [id])
  lines      PurchaseReceiptLine[]

  @@map("purchase_receipts")
}

model PurchaseReceiptLine {
  id                String   @id @default(cuid())
  purchaseReceiptId String   @map("purchase_receipt_id")
  inventoryItemId   String   @map("inventory_item_id")
  quantity          Decimal  @db.Decimal(18, 4)
  unitCost          Decimal? @map("unit_cost") @db.Decimal(18, 2)
  /// Monto total pagado en la línea (ej. factura de la caneca). Informes: tal cual. Costo medio usa este total.
  lineTotalCost     Decimal? @map("line_total_cost") @db.Decimal(18, 2)

  purchaseReceipt PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([purchaseReceiptId])
  @@index([inventoryItemId])
  @@map("purchase_receipt_lines")
}

/// Movimiento de inventario (trazabilidad; cantidad con signo).
model InventoryMovement {
  id                String                 @id @default(cuid())
  inventoryItemId   String                 @map("inventory_item_id")
  quantityChange    Decimal                @map("quantity_change") @db.Decimal(18, 4)
  movementType      InventoryMovementType  @map("movement_type")
  referenceType     String?                @map("reference_type") @db.VarChar(80)
  referenceId       String?                @map("reference_id") @db.VarChar(40)
  note                String?                @db.Text
  createdById       String                 @map("created_by_id")
  createdAt           DateTime               @default(now()) @map("created_at")

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  createdBy     User          @relation("InventoryMovementCreatedBy", fields: [createdById], references: [id])

  @@index([inventoryItemId, createdAt])
  @@map("inventory_movements")
}

/// Línea de orden (repuesto con stock o mano de obra).
model WorkOrderLine {
  id              String            @id @default(cuid())
  workOrderId     String            @map("work_order_id")
  lineType        WorkOrderLineType @map("line_type")
  sortOrder       Int               @default(0) @map("sort_order")
  inventoryItemId String?           @map("inventory_item_id")
  /// Servicio del catálogo cuando la línea LABOR nace de un servicio predefinido.
  /// Opcional: si es null, se mantiene el flujo histórico de mano de obra libre.
  serviceId       String?           @map("service_id")
  /// Tarifa de impuesto aplicada a esta línea (IVA/INC). Null = sin impuesto / línea legada.
  taxRateId       String?           @map("tax_rate_id")
  description     String?           @db.VarChar(2000)
  quantity        Decimal           @db.Decimal(18, 4)
  unitPrice       Decimal?          @map("unit_price") @db.Decimal(18, 2)
  /// Descuento en pesos sobre la línea (no porcentaje; calculado por el cliente). Null = 0.
  discountAmount  Decimal?          @map("discount_amount") @db.Decimal(18, 2)
  /// Copia del costo medio al momento de crear la línea (margen histórico sin depender del costo actual).
  costSnapshot    Decimal?          @map("cost_snapshot") @db.Decimal(18, 2)
  /// Porcentaje del impuesto congelado al momento de guardar la línea (null = sin impuesto).
  /// Evita que un cambio futuro en `TaxRate.ratePercent` altere totales de OTs ya emitidas.
  taxRatePercentSnapshot Decimal?   @map("tax_rate_percent_snapshot") @db.Decimal(5, 2)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  workOrder       WorkOrder        @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  inventoryItem   InventoryItem?   @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  service         Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  taxRate         TaxRate?         @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  @@index([workOrderId, sortOrder])
  @@index([serviceId])
  @@index([taxRateId])
  @@map("work_order_lines")
}

/// Catálogo de servicios del taller (mano de obra predefinida: diagnóstico, alineación, cambio de aceite…).
/// Los servicios NO son inventario: no tienen stock ni costo promedio; pueden tener IVA distinto.
model Service {
  id               String    @id @default(cuid())
  /// Código de negocio / SKU del servicio (ej. SRV-DIAG, SRV-CAMBIO-ACEITE). Único.
  code             String    @unique @db.VarChar(60)
  name             String    @db.VarChar(200)
  description      String?   @db.Text
  /// Precio sugerido en COP (entero); si es null, el cajero/administración lo pone en la OT.
  defaultUnitPrice Decimal?  @map("default_unit_price") @db.Decimal(18, 2)
  /// Tarifa de impuesto sugerida al agregar el servicio a una OT o venta.
  defaultTaxRateId String?   @map("default_tax_rate_id")
  isActive         Boolean   @default(true) @map("is_active")
  sortOrder        Int       @default(0) @map("sort_order")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  defaultTaxRate   TaxRate?        @relation("ServiceDefaultTaxRate", fields: [defaultTaxRateId], references: [id], onDelete: SetNull)
  workOrderLines   WorkOrderLine[]
  saleLines        SaleLine[]
  invoiceLines     InvoiceLine[]

  @@index([isActive, sortOrder])
  @@map("services")
}

/// Tarifa de impuesto indirecto (IVA o INC). Catálogo compartido por servicios, ventas y facturas.
/// Preferir `isActive=false` antes que borrar para mantener auditoría fiscal.
model TaxRate {
  id          String      @id @default(cuid())
  /// Identificador estable para API/UI (ej. `iva_19`, `iva_5`, `iva_0`, `inc_8`).
  slug        String      @unique @db.VarChar(40)
  name        String      @db.VarChar(120)
  kind        TaxRateKind
  /// Porcentaje 0–100 con 2 decimales (ej. 19.00, 5.00).
  ratePercent Decimal     @map("rate_percent") @db.Decimal(5, 2)
  isActive    Boolean     @default(true) @map("is_active")
  /// Tarifa sugerida por defecto en la UI. Solo una por `kind` debería tenerlo (regla de aplicación).
  isDefault   Boolean     @default(false) @map("is_default")
  sortOrder   Int         @default(0) @map("sort_order")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  servicesAsDefault Service[]       @relation("ServiceDefaultTaxRate")
  workOrderLines    WorkOrderLine[]
  saleLines         SaleLine[]
  invoiceLines      InvoiceLine[]

  @@index([isActive, sortOrder])
  @@map("tax_rates")
}

/// Sesión de caja (apertura/cierre). Solo una sesión OPEN a la vez (regla de negocio en servicio).
model CashSession {
  id              String            @id @default(cuid())
  status          CashSessionStatus @default(OPEN)
  openedAt        DateTime          @default(now()) @map("opened_at")
  closedAt        DateTime?         @map("closed_at")
  openedById      String            @map("opened_by_id")
  closedById      String?           @map("closed_by_id")
  openingAmount   Decimal           @map("opening_amount") @db.Decimal(18, 2)
  closingExpected Decimal?          @map("closing_expected") @db.Decimal(18, 2)
  closingCounted  Decimal?          @map("closing_counted") @db.Decimal(18, 2)
  differenceNote  String?           @map("difference_note")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  openedBy  User           @relation("CashSessionOpenedBy", fields: [openedById], references: [id])
  closedBy  User?          @relation("CashSessionClosedBy", fields: [closedById], references: [id])
  movements CashMovement[]

  @@index([status])
  @@map("cash_sessions")
}

/// Categoría de movimiento (ingreso/egreso). Catálogo estable por slug.
model CashMovementCategory {
  id        String                @id @default(cuid())
  slug      String                @unique
  name      String
  direction CashMovementDirection
  isSystem  Boolean               @default(true) @map("is_system")
  sortOrder Int                   @default(0) @map("sort_order")

  movements       CashMovement[]
  expenseRequests CashExpenseRequest[]

  @@map("cash_movement_categories")
}

/// Movimiento de caja (append-only). Referencia opcional a orden/compra/etc. en fases posteriores.
model CashMovement {
  id            String                @id @default(cuid())
  sessionId     String                @map("session_id")
  categoryId    String                @map("category_id")
  direction     CashMovementDirection
  amount        Decimal               @db.Decimal(18, 2)
  /// Efectivo entregado (ingreso) o total en mano para cubrir el egreso; opcional.
  tenderAmount  Decimal?              @map("tender_amount") @db.Decimal(18, 2)
  /// Vuelto: tender − amount (calculado en servidor).
  changeAmount  Decimal?              @map("change_amount") @db.Decimal(18, 2)
  referenceType String?               @map("reference_type")
  referenceId   String?               @map("reference_id")
  note          String?
  createdById   String                @map("created_by_id")
  createdAt     DateTime              @default(now()) @map("created_at")

  session                CashSession          @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  category               CashMovementCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy              User                 @relation("CashMovementCreatedBy", fields: [createdById], references: [id])
  /// Si el movimiento nació de una solicitud aprobada, enlaza 1:1 con esa solicitud.
  approvedExpenseRequest CashExpenseRequest?  @relation("MovementFromApprovedExpenseRequest")
  workOrderPayment       WorkOrderPayment?
  salePayment            SalePayment?
  invoicePayment         InvoicePayment?

  @@index([sessionId, createdAt])
  @@map("cash_movements")
}

/// Hasta 3 usuarios de confianza pueden registrar egresos operativos (además de elevados). Regla en servicio.
model CashExpenseDelegate {
  userId       String   @id @map("user_id")
  assignedById String   @map("assigned_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User @relation("CashExpenseDelegateUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User @relation("CashExpenseDelegateAssigner", fields: [assignedById], references: [id])

  @@map("cash_expense_delegates")
}

/**
 * Solicitud de egreso cuando nadie con egreso directo está disponible.
 * Tras aprobar (APPROVED), el cajero registra el egreso con `pay-out`; entonces se crea el movimiento y `resultMovementId`.
 */
model CashExpenseRequest {
  id               String                   @id @default(cuid())
  status           CashExpenseRequestStatus @default(PENDING)
  categoryId       String                   @map("category_id")
  amount           Decimal                  @db.Decimal(18, 2)
  referenceType    String?                  @map("reference_type")
  referenceId      String?                  @map("reference_id")
  note             String?
  requestedById    String                   @map("requested_by_id")
  reviewedById     String?                  @map("reviewed_by_id")
  reviewedAt       DateTime?                @map("reviewed_at")
  rejectionReason  String?                  @map("rejection_reason")
  approvalNote     String?                  @map("approval_note")
  resultMovementId String?                  @unique @map("result_movement_id")
  expiresAt        DateTime?                @map("expires_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  category       CashMovementCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  requestedBy    User                 @relation("CashExpenseRequestRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy     User?                @relation("CashExpenseRequestReviewer", fields: [reviewedById], references: [id])
  resultMovement CashMovement?        @relation("MovementFromApprovedExpenseRequest", fields: [resultMovementId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requestedById, createdAt])
  @@map("cash_expense_requests")
}

/// Plantilla de permisos (administrador, cajero, etc.). Los permisos finales son la unión por rol.
model Role {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

/// Permiso granular: recurso lógico + acción (ej. users:read).
model Permission {
  id          String  @id @default(cuid())
  resource    String
  action      String
  description String?

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

/// Trazabilidad append-only de acciones relevantes (dominio + HTTP sensible).
model AuditLog {
  id              String   @id @default(cuid())
  actorUserId     String?  @map("actor_user_id")
  action          String
  entityType      String   @map("entity_type")
  entityId        String?  @map("entity_id")
  previousPayload Json?    @map("previous_payload")
  nextPayload     Json?    @map("next_payload")
  reason          String?
  requestId       String?  @map("request_id")
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Configuración del taller (clave → JSON). Evoluciona sin migraciones por cada bandera nueva.
model WorkshopSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  updatedBy User? @relation("SettingUpdater", fields: [updatedById], references: [id])

  @@map("workshop_settings")
}

/// Venta de mostrador o comprobante emitido desde una OT (Fase 3).
///
/// Reglas clave:
/// - `origin = COUNTER`: venta directa. Al confirmar, las líneas PART descuentan inventario
///   vía `InventoryMovement` tipo `SALE_CONSUMPTION`.
/// - `origin = WORK_ORDER`: requiere `originWorkOrderId` apuntando a una OT ya entregada.
///   **No** reconsume inventario (la OT ya generó `WORK_ORDER_CONSUMPTION`); solo sirve
///   para emitir el comprobante y manejar el cobro si el taller lo registra aquí.
/// - Una OT solo puede tener una venta derivada (unique sobre `originWorkOrderId`).
/// - Los snapshots de cliente se guardan para preservar el comprobante aunque el maestro cambie.
model Sale {
  id                 String     @id @default(cuid())
  saleNumber         Int        @unique @default(autoincrement()) @map("sale_number")
  /// Código humano para el comprobante (ej. VTA-0001). Se asigna al crear según `saleNumber`.
  publicCode         String     @unique @map("public_code") @db.VarChar(32)
  status             SaleStatus @default(DRAFT)
  origin             SaleOrigin @default(COUNTER)
  originWorkOrderId  String?    @unique @map("origin_work_order_id")
  customerId         String?    @map("customer_id")
  /// Snapshots fiscales tomados al confirmar (mantienen el comprobante estable aunque el cliente cambie).
  customerName       String?    @map("customer_name") @db.VarChar(200)
  customerDocumentId String?    @map("customer_document_id") @db.VarChar(40)
  customerPhone      String?    @map("customer_phone") @db.VarChar(40)
  customerEmail      String?    @map("customer_email") @db.VarChar(120)
  internalNotes      String?    @map("internal_notes") @db.Text
  confirmedAt        DateTime?  @map("confirmed_at")
  cancelledAt        DateTime?  @map("cancelled_at")
  cancelledReason    String?    @map("cancelled_reason") @db.Text
  createdById        String     @map("created_by_id")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  originWorkOrder WorkOrder?   @relation(fields: [originWorkOrderId], references: [id], onDelete: Restrict)
  customer        Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy       User         @relation("SaleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines           SaleLine[]
  payments        SalePayment[]
  invoices        Invoice[]

  @@index([status, createdAt])
  @@index([customerId])
  @@index([createdById])
  @@map("sales")
}

/// Línea de venta. Estructura paralela a `WorkOrderLine` para reutilizar el motor de totales.
model SaleLine {
  id                     String        @id @default(cuid())
  saleId                 String        @map("sale_id")
  lineType               SaleLineType  @map("line_type")
  sortOrder              Int           @default(0) @map("sort_order")
  inventoryItemId        String?       @map("inventory_item_id")
  serviceId              String?       @map("service_id")
  taxRateId              String?       @map("tax_rate_id")
  description            String?       @db.VarChar(2000)
  quantity               Decimal       @db.Decimal(18, 4)
  unitPrice              Decimal?      @map("unit_price") @db.Decimal(18, 2)
  discountAmount         Decimal?      @map("discount_amount") @db.Decimal(18, 2)
  costSnapshot           Decimal?      @map("cost_snapshot") @db.Decimal(18, 2)
  /// Porcentaje del impuesto congelado al guardar (null = sin impuesto). Paridad con WorkOrderLine.
  taxRatePercentSnapshot Decimal?      @map("tax_rate_percent_snapshot") @db.Decimal(5, 2)
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  service       Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  @@index([saleId, sortOrder])
  @@index([inventoryItemId])
  @@index([serviceId])
  @@index([taxRateId])
  @@map("sale_lines")
}

/// Cobro registrado en caja vinculado a una venta (1:1 con el movimiento de ingreso).
model SalePayment {
  id             String          @id @default(cuid())
  saleId         String          @map("sale_id")
  amount         Decimal         @db.Decimal(18, 2)
  kind           SalePaymentKind @default(PARTIAL)
  cashMovementId String          @unique @map("cash_movement_id")
  note           String?
  recordedById   String          @map("recorded_by_id")
  createdAt      DateTime        @default(now()) @map("created_at")

  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Restrict)
  cashMovement CashMovement @relation(fields: [cashMovementId], references: [id], onDelete: Restrict)
  recordedBy   User         @relation("SalePaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([saleId, createdAt])
  @@map("sale_payments")
}

// ============================================================================
// Fase 4 · Factura electrónica DIAN (preparación; inactiva hasta configurar proveedor).
// ============================================================================

/// Tipo de resolución DIAN. Distingue el ámbito de numeración fiscal:
/// - `ELECTRONIC_INVOICE`: factura electrónica estándar (FE).
/// - `POS`: documento equivalente POS (tiquete electrónico).
/// - `CONTINGENCY`: numeración de contingencia / talonario físico.
enum FiscalResolutionKind {
  ELECTRONIC_INVOICE
  POS
  CONTINGENCY
}

/// Ciclo de vida de una factura emitida.
/// - `DRAFT`: local, aún no enviada al proveedor DIAN (o DIAN está apagado).
/// - `ISSUED`: aceptada por el proveedor / DIAN (con CUFE guardado).
/// - `VOIDED`: invalidada antes de ser aceptada; si ya estaba aceptada se usa CreditNote.
enum InvoiceStatus {
  DRAFT
  ISSUED
  VOIDED
}

/// De qué documento operativo nació la factura.
enum InvoiceSource {
  SALE
  WORK_ORDER
}

/// Paridad con `SaleLineType` / `WorkOrderLineType` (mantenemos un enum propio para
/// desacoplar la factura del modelo operativo: si cambian esos tipos, la factura no muta).
enum InvoiceLineType {
  PART
  LABOR
}

/// Estado de un intento de envío de factura/NC al proveedor DIAN.
enum InvoiceDispatchStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  ERROR
  NOT_CONFIGURED
}

/// Motivo normalizado de una nota crédito.
enum CreditNoteReason {
  VOID
  ADJUSTMENT
  RETURN
  DISCOUNT
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  VOIDED
}

/// Motivo normalizado de una nota débito (incremento fiscal sobre factura).
enum DebitNoteReason {
  PRICE_CORRECTION
  ADDITIONAL_CHARGE
  INTEREST
  OTHER
}

enum DebitNoteStatus {
  DRAFT
  ISSUED
  VOIDED
}

/// Resolución DIAN: autoriza un rango de numeración con prefijo.
///
/// Reglas operativas:
/// - `nextNumber` es el **próximo** número a usar (no el último consumido). Se avanza
///   atómicamente al emitir cada factura/NC con `FOR UPDATE`.
/// - Cuando `nextNumber > rangeTo`, la resolución se considera agotada (el servicio
///   rechaza emitir más). El taller debe registrar una nueva resolución.
/// - `isDefault` marca la resolución preferida por tipo; el índice parcial de la migración
///   garantiza una sola default activa por `kind`.
model FiscalResolution {
  id                 String               @id @default(cuid())
  kind               FiscalResolutionKind @default(ELECTRONIC_INVOICE)
  /// Número de la resolución emitida por la DIAN (texto).
  resolutionNumber   String               @map("resolution_number") @db.VarChar(80)
  prefix             String               @db.VarChar(16)
  rangeFrom          Int                  @map("range_from")
  rangeTo            Int                  @map("range_to")
  /// Próximo número a asignar. Se inicializa en `rangeFrom`.
  nextNumber         Int                  @map("next_number")
  validFrom          DateTime?            @map("valid_from") @db.Date
  validUntil         DateTime?            @map("valid_until") @db.Date
  /// Clave técnica provista por DIAN para FE (opcional, va al XML).
  technicalKey       String?              @map("technical_key") @db.VarChar(200)
  /// Identificador de set de prueba / habilitación (sandbox) cuando aplica.
  testSetId          String?              @map("test_set_id") @db.VarChar(80)
  isActive           Boolean              @default(true) @map("is_active")
  isDefault          Boolean              @default(false) @map("is_default")
  notes              String?              @db.Text
  createdById        String?              @map("created_by_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  createdBy   User?        @relation("FiscalResolutionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  invoices    Invoice[]
  creditNotes CreditNote[]
  debitNotes  DebitNote[]

  @@unique([kind, prefix, resolutionNumber])
  @@index([kind, isActive])
  @@map("fiscal_resolutions")
}

/// Factura (o documento equivalente POS) emitida por el taller. Snapshot inmutable.
model Invoice {
  id                   String          @id @default(cuid())
  fiscalResolutionId   String          @map("fiscal_resolution_id")
  /// Número asignado desde la resolución (sin prefijo).
  invoiceNumber        Int             @map("invoice_number")
  /// `{prefix}{invoiceNumber}` — identificador humano único global.
  documentNumber       String          @unique @map("document_number") @db.VarChar(48)
  status               InvoiceStatus   @default(DRAFT)
  source               InvoiceSource
  saleId               String?         @map("sale_id")
  workOrderId          String?         @map("work_order_id")

  customerId           String?         @map("customer_id")
  customerName         String          @map("customer_name") @db.VarChar(200)
  customerDocumentId   String?         @map("customer_document_id") @db.VarChar(40)
  customerPhone        String?         @map("customer_phone") @db.VarChar(40)
  customerEmail        String?         @map("customer_email") @db.VarChar(120)

  subtotal             Decimal         @db.Decimal(18, 2)
  totalDiscount        Decimal         @default(0) @map("total_discount") @db.Decimal(18, 2)
  totalTax             Decimal         @default(0) @map("total_tax") @db.Decimal(18, 2)
  totalVat             Decimal         @default(0) @map("total_vat") @db.Decimal(18, 2)
  totalInc             Decimal         @default(0) @map("total_inc") @db.Decimal(18, 2)
  grandTotal           Decimal         @map("grand_total") @db.Decimal(18, 2)

  /// CUFE (Código Único de Facturación Electrónica) provisto por DIAN al aceptar. Null = aún no emitida.
  cufe                 String?         @db.VarChar(128)
  dianProvider         String?         @map("dian_provider") @db.VarChar(40)
  dianEnvironment      String?         @map("dian_environment") @db.VarChar(20)
  issuedAt             DateTime?       @map("issued_at")
  voidedAt             DateTime?       @map("voided_at")
  voidedReason         String?         @map("voided_reason") @db.Text

  internalNotes        String?         @map("internal_notes") @db.Text
  createdById          String          @map("created_by_id")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  fiscalResolution FiscalResolution        @relation(fields: [fiscalResolutionId], references: [id], onDelete: Restrict)
  sale             Sale?                   @relation(fields: [saleId], references: [id], onDelete: Restrict)
  workOrder        WorkOrder?              @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  customer         Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy        User                    @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines            InvoiceLine[]
  dispatchEvents   InvoiceDispatchEvent[]
  creditNotes      CreditNote[]
  debitNotes       DebitNote[]
  payments         InvoicePayment[]

  @@unique([fiscalResolutionId, invoiceNumber])
  @@index([status, createdAt])
  @@index([customerId])
  @@index([createdById])
  @@map("invoices")
}

/// Línea de factura (snapshot; no editable después de crear).
model InvoiceLine {
  id                     String            @id @default(cuid())
  invoiceId              String            @map("invoice_id")
  lineType               InvoiceLineType   @map("line_type")
  sortOrder              Int               @default(0) @map("sort_order")
  /// Línea operativa de origen (SaleLine o WorkOrderLine); sirve para conciliar.
  sourceSaleLineId       String?           @map("source_sale_line_id")
  sourceWorkOrderLineId  String?           @map("source_work_order_line_id")
  inventoryItemId        String?           @map("inventory_item_id")
  serviceId              String?           @map("service_id")
  taxRateId              String?           @map("tax_rate_id")
  description            String?           @db.VarChar(2000)
  quantity               Decimal           @db.Decimal(18, 4)
  unitPrice              Decimal           @map("unit_price") @db.Decimal(18, 2)
  discountAmount         Decimal           @default(0) @map("discount_amount") @db.Decimal(18, 2)
  taxRatePercentSnapshot Decimal           @default(0) @map("tax_rate_percent_snapshot") @db.Decimal(5, 2)
  taxRateKindSnapshot    TaxRateKind?      @map("tax_rate_kind_snapshot")
  lineTotal              Decimal           @map("line_total") @db.Decimal(18, 2)
  taxAmount              Decimal           @default(0) @map("tax_amount") @db.Decimal(18, 2)
  createdAt              DateTime          @default(now()) @map("created_at")

  invoice          Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem?       @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  service          Service?             @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  taxRate          TaxRate?             @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  creditNoteLines  CreditNoteLine[]

  @@index([invoiceId, sortOrder])
  @@index([inventoryItemId])
  @@index([serviceId])
  @@map("invoice_lines")
}

/// Bitácora/cola de intentos de envío al proveedor DIAN.
/// Cada intento queda aquí con payload, respuesta y error (si lo hubo).
model InvoiceDispatchEvent {
  id              String                @id @default(cuid())
  invoiceId       String                @map("invoice_id")
  attempt         Int                   @default(1)
  status          InvoiceDispatchStatus @default(PENDING)
  provider        String?               @db.VarChar(40)
  environment     String?               @db.VarChar(20)
  requestPayload  Json?                 @map("request_payload")
  responsePayload Json?                 @map("response_payload")
  errorMessage    String?               @map("error_message") @db.Text
  externalId      String?               @map("external_id") @db.VarChar(128)
  requestedAt     DateTime              @default(now()) @map("requested_at")
  completedAt     DateTime?             @map("completed_at")
  requestedById   String?               @map("requested_by_id")

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  requestedBy User?   @relation("InvoiceDispatchRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([invoiceId, requestedAt])
  @@index([status])
  @@map("invoice_dispatch_events")
}

/// Nota crédito: corrige o anula una factura ya emitida. Siempre contra una Invoice concreta.
model CreditNote {
  id                   String             @id @default(cuid())
  fiscalResolutionId   String             @map("fiscal_resolution_id")
  creditNoteNumber     Int                @map("credit_note_number")
  documentNumber       String             @unique @map("document_number") @db.VarChar(48)
  invoiceId            String             @map("invoice_id")
  status               CreditNoteStatus   @default(DRAFT)
  reason               CreditNoteReason
  reasonDescription    String             @map("reason_description") @db.Text

  subtotal             Decimal            @db.Decimal(18, 2)
  totalDiscount        Decimal            @default(0) @map("total_discount") @db.Decimal(18, 2)
  totalTax             Decimal            @default(0) @map("total_tax") @db.Decimal(18, 2)
  grandTotal           Decimal            @map("grand_total") @db.Decimal(18, 2)

  cufe                 String?            @db.VarChar(128)
  dianProvider         String?            @map("dian_provider") @db.VarChar(40)
  dianEnvironment      String?            @map("dian_environment") @db.VarChar(20)
  issuedAt             DateTime?          @map("issued_at")
  issuedById           String?            @map("issued_by_id")
  voidedAt             DateTime?          @map("voided_at")
  voidedReason         String?            @map("voided_reason") @db.Text
  voidedById           String?            @map("voided_by_id")

  createdById          String             @map("created_by_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  fiscalResolution FiscalResolution @relation(fields: [fiscalResolutionId], references: [id], onDelete: Restrict)
  invoice          Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  createdBy        User             @relation("CreditNoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  issuedBy         User?            @relation("CreditNoteIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  voidedBy         User?            @relation("CreditNoteVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  lines            CreditNoteLine[]

  @@unique([fiscalResolutionId, creditNoteNumber])
  @@index([invoiceId])
  @@index([status, createdAt])
  @@map("credit_notes")
}

model CreditNoteLine {
  id                     String            @id @default(cuid())
  creditNoteId           String            @map("credit_note_id")
  sourceInvoiceLineId    String?           @map("source_invoice_line_id")
  lineType               InvoiceLineType   @map("line_type")
  sortOrder              Int               @default(0) @map("sort_order")
  description            String            @db.VarChar(2000)
  quantity               Decimal           @db.Decimal(18, 4)
  unitPrice              Decimal           @map("unit_price") @db.Decimal(18, 2)
  discountAmount         Decimal           @default(0) @map("discount_amount") @db.Decimal(18, 2)
  taxRatePercentSnapshot Decimal           @default(0) @map("tax_rate_percent_snapshot") @db.Decimal(5, 2)
  taxRateKindSnapshot    TaxRateKind?      @map("tax_rate_kind_snapshot")
  lineTotal              Decimal           @map("line_total") @db.Decimal(18, 2)
  taxAmount              Decimal           @default(0) @map("tax_amount") @db.Decimal(18, 2)
  createdAt              DateTime          @default(now()) @map("created_at")

  creditNote        CreditNote   @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  sourceInvoiceLine InvoiceLine? @relation(fields: [sourceInvoiceLineId], references: [id], onDelete: SetNull)

  @@index([creditNoteId, sortOrder])
  @@map("credit_note_lines")
}

/// Nota débito: incrementa el valor cobrado de una factura emitida (correcciones de precio,
/// recargos, intereses). Fase 7: la emisión de una DN aceptada reabre el cobro en caja,
/// ya que `effectiveAmount = grandTotal - SUM(CN issued) + SUM(DN issued)`.
model DebitNote {
  id                   String           @id @default(cuid())
  fiscalResolutionId   String           @map("fiscal_resolution_id")
  debitNoteNumber      Int              @map("debit_note_number")
  documentNumber       String           @unique @map("document_number") @db.VarChar(48)
  invoiceId            String           @map("invoice_id")
  status               DebitNoteStatus  @default(DRAFT)
  reason               DebitNoteReason
  reasonDescription    String           @map("reason_description") @db.Text

  subtotal             Decimal          @db.Decimal(18, 2)
  totalDiscount        Decimal          @default(0) @map("total_discount") @db.Decimal(18, 2)
  totalTax             Decimal          @default(0) @map("total_tax") @db.Decimal(18, 2)
  grandTotal           Decimal          @map("grand_total") @db.Decimal(18, 2)

  cufe                 String?          @db.VarChar(128)
  dianProvider         String?          @map("dian_provider") @db.VarChar(40)
  dianEnvironment      String?          @map("dian_environment") @db.VarChar(20)
  issuedAt             DateTime?        @map("issued_at")
  issuedById           String?          @map("issued_by_id")
  voidedAt             DateTime?        @map("voided_at")
  voidedReason         String?          @map("voided_reason") @db.Text
  voidedById           String?          @map("voided_by_id")

  createdById          String           @map("created_by_id")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  fiscalResolution FiscalResolution @relation(fields: [fiscalResolutionId], references: [id], onDelete: Restrict)
  invoice          Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  createdBy        User             @relation("DebitNoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  issuedBy         User?            @relation("DebitNoteIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  voidedBy         User?            @relation("DebitNoteVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  lines            DebitNoteLine[]

  @@unique([fiscalResolutionId, debitNoteNumber])
  @@index([invoiceId])
  @@index([status, createdAt])
  @@map("debit_notes")
}

model DebitNoteLine {
  id                     String            @id @default(cuid())
  debitNoteId            String            @map("debit_note_id")
  lineType               InvoiceLineType   @map("line_type")
  sortOrder              Int               @default(0) @map("sort_order")
  description            String            @db.VarChar(2000)
  quantity               Decimal           @db.Decimal(18, 4)
  unitPrice              Decimal           @map("unit_price") @db.Decimal(18, 2)
  discountAmount         Decimal           @default(0) @map("discount_amount") @db.Decimal(18, 2)
  taxRatePercentSnapshot Decimal           @default(0) @map("tax_rate_percent_snapshot") @db.Decimal(5, 2)
  taxRateKindSnapshot    TaxRateKind?      @map("tax_rate_kind_snapshot")
  lineTotal              Decimal           @map("line_total") @db.Decimal(18, 2)
  taxAmount              Decimal           @default(0) @map("tax_amount") @db.Decimal(18, 2)
  createdAt              DateTime          @default(now()) @map("created_at")

  debitNote DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)

  @@index([debitNoteId, sortOrder])
  @@map("debit_note_lines")
}

// ============================================================================
// Fase 5 · Pagos de factura (cobro directo en caja contra una Invoice).
// ============================================================================

/// Tipología de cobro sobre una factura: abono (deja saldo) o liquidación total.
enum InvoicePaymentKind {
  PARTIAL
  FULL_SETTLEMENT
}

/// Pago asociado a una factura emitida desde el taller. 1:1 con `CashMovement`
/// (no se permite borrar el movimiento sin borrar antes el pago). El saldo
/// pendiente se calcula por diferencia (grandTotal − SUM(amount)).
model InvoicePayment {
  id             String             @id @default(cuid())
  invoiceId      String             @map("invoice_id")
  amount         Decimal            @db.Decimal(18, 2)
  kind           InvoicePaymentKind @default(PARTIAL)
  cashMovementId String             @unique @map("cash_movement_id")
  note           String?
  recordedById   String             @map("recorded_by_id")
  createdAt      DateTime           @default(now()) @map("created_at")

  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  cashMovement CashMovement @relation(fields: [cashMovementId], references: [id], onDelete: Restrict)
  recordedBy   User         @relation("InvoicePaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([invoiceId, createdAt])
  @@map("invoice_payments")
}

